{
	"name": "API_Ingestion",
	"properties": {
		"activities": [
			{
				"name": "API_to_ADLS",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "RestSource",
						"httpRequestTimeout": "00:01:40",
						"requestInterval": "00.00:00:00.010",
						"requestMethod": "GET",
						"paginationRules": {
							"AbsoluteUrl": "$.$.next"
						}
					},
					"sink": {
						"type": "JsonSink",
						"storeSettings": {
							"type": "AzureBlobFSWriteSettings",
							"copyBehavior": "FlattenHierarchy"
						},
						"formatSettings": {
							"type": "JsonWriteSettings",
							"filePattern": "setOfObjects"
						}
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"mappings": [
							{
								"source": {
									"path": "$['count']"
								}
							},
							{
								"source": {
									"path": "$['next']"
								}
							},
							{
								"source": {
									"path": "$['previous']"
								}
							},
							{
								"source": {
									"path": "['name']"
								}
							},
							{
								"source": {
									"path": "['height']"
								}
							},
							{
								"source": {
									"path": "['mass']"
								}
							},
							{
								"source": {
									"path": "['hair_color']"
								}
							},
							{
								"source": {
									"path": "['skin_color']"
								}
							},
							{
								"source": {
									"path": "['eye_color']"
								}
							},
							{
								"source": {
									"path": "['birth_year']"
								}
							},
							{
								"source": {
									"path": "['gender']"
								}
							},
							{
								"source": {
									"path": "['homeworld']"
								}
							},
							{
								"source": {
									"path": "['films'][0]"
								}
							},
							{
								"source": {
									"path": "['species'][0]"
								}
							},
							{
								"source": {
									"path": "['vehicles'][0]"
								}
							},
							{
								"source": {
									"path": "['starships'][0]"
								}
							},
							{
								"source": {
									"path": "['created']"
								}
							},
							{
								"source": {
									"path": "['edited']"
								}
							},
							{
								"source": {
									"path": "['url']"
								}
							}
						],
						"collectionReference": "$['results']"
					}
				},
				"inputs": [
					{
						"referenceName": "DS_Rest",
						"type": "DatasetReference"
					}
				],
				"outputs": [
					{
						"referenceName": "DS_Json",
						"type": "DatasetReference"
					}
				]
			}
		],
		"annotations": []
	}
}